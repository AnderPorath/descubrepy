PORT=6000

# PostgreSQL (Render / producción) - recomendado
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Si tu proveedor requiere SSL, dejá esto en true (Render suele requerirlo)
DATABASE_SSL=true

# PostgreSQL (local, opcional; si no usás DATABASE_URL)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=descubrepy
PGUSER=postgres
PGPASSWORD=

JWT_SECRET=cambiar-en-produccion-secreto-muy-largo
NODE_ENV=development

# Producción (Render): ruta del disco persistente para que las fotos no desaparezcan en redeploys
# Ejemplo después de agregar un Disk en Render: UPLOAD_DIR=/opt/render/project/data/uploads
# UPLOAD_DIR=

# Email: necesario para "Solicitá tu publicación" (Anunciate) y para notificaciones al registrar empresas.
# Sin esto, el formulario de contacto devuelve error. Usar Gmail con "Contraseña de aplicación":
# 1. https://myaccount.google.com/apppasswords → crear contraseña de aplicación.
# 2. Descomentar y completar abajo (sin espacios en EMAIL_APP_PASSWORD).
# EMAIL_USER=descubrepy.com.py@gmail.com
# EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
